{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src",
    "entrypoints",
    ".wxt/wxt.d.ts",
    ".wxt/types"
  ],
  "exclude": [
    "node_modules",
    ".output"
  ]
}
